# User-uploaded content — never commit. NOTE: trailing inline comments on a
# gitignore pattern line do NOT work with this git version — the whole line
# (pattern + comment) is treated as literal and never matches anything.
# Keep comments on their own line above the pattern, always.
# user-uploaded logos
assets/user_branding/
# user-uploaded fonts (often licensed)
assets/user_fonts/
# voice reference for TTS cloning
assets/user_voice/
# user-uploaded avatar images
assets/user_avatars/
# generated preview thumbnails
cache/font_previews/
config.local.yaml
# local binaries (e.g. driver-compatible ffmpeg) — never commit
tools/

# Reference videos for the style analyzer — never commit (may be copyrighted).
refs/

.claude/settings.local.json

.claude/
CLAUDE.md

