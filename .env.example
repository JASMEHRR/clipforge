# ClipForge secrets — copy to .env and fill in what you use.
# The app runs fully WITHOUT this file (mock LLM provider + deterministic fallbacks).

# Google AI Studio key (free tier works): https://aistudio.google.com/apikey
# When set and provider=auto, ClipForge uses Gemini automatically.
GEMINI_API_KEY=

# Optional alternatives (select via config.yaml: llm.provider)
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# YouTube upload (optional). Path to the OAuth client secrets JSON you download
# from Google Cloud Console (Desktop app credential). See README "YouTube upload".
YOUTUBE_CLIENT_SECRETS=
